#!/usr/bin/env bash
# validate-page — unified wiki page validator
# Usage: validate-page [path/to/page.md]
#   With no argument, validates all wiki pages.
#   With a path, validates that single page.
#
# This is the wiki equivalent of `skills-ref validate` — catch mechanical
# issues fast before spawning editors. Checks frontmatter, links, sources,
# structure, and orphan/index coverage.

set -uo pipefail

cd "$(git rev-parse --show-toplevel)"

ERRORS=0
WARNS=0

check() {
  local severity="$1"; shift
  local msg="$*"
  if [ "$severity" = "ERROR" ]; then
    echo "  🚨 $msg"
    ERRORS=$((ERRORS + 1))
  else
    echo "  ⚠️  $msg"
    WARNS=$((WARNS + 1))
  fi
}

has_frontmatter_field() {
  local file="$1" field="$2"
  awk "/^---\$/{n++; next} n==1 && /^${field}:/{found=1; exit} END{exit !found}" "$file" 2>/dev/null || true
  # awk exit 1 means not found, but we don't want that to kill the script
  # We check the return status via the caller
  awk "/^---\$/{n++; next} n==1 && /^${field}:/{found=1; exit} END{exit !found}" "$file" >/dev/null 2>/dev/null
}

validate_one() {
  local f="$1"
  local slug=$(basename "$f" .md)

  # Skip index.md
  [ "$slug" = "index" ] && return

  # --- Frontmatter presence ---
  if ! head -1 "$f" | grep -q '^---$'; then
    check ERROR "$f: missing YAML frontmatter"
    return
  fi

  # --- Required fields ---
  for field in title created updated sources tags; do
    if ! awk "/^---\$/{n++; next} n==1 && /^${field}:/{found=1; exit} END{exit !found}" "$f" >/dev/null 2>/dev/null; then
      check ERROR "$f: missing frontmatter field '$field'"
    fi
  done

  # --- Date format (YYYY-MM-DD) ---
  for date_field in created updated; do
    val=$(awk "/^---\$/{n++; next} n==1 && /^${date_field}:/{print \$2; exit}" "$f" || true)
    if [ -n "$val" ] && ! echo "$val" | grep -qP '^\d{4}-\d{2}-\d{2}$'; then
      check ERROR "$f: frontmatter '$date_field' is not YYYY-MM-DD: $val"
    fi
  done

  # --- Summary blockquote after # Title ---
  result=$(awk '
    /^---$/{fm++; next}
    fm<2{next}
    /^# /{found_title=1; next}
    found_title && /^$/{next}
    found_title && /^> /{print "ok"; exit}
    found_title{exit}
    END{if(!found_title) print "notitle"}
  ' "$f" || true)
  [ "$result" != "ok" ] && check ERROR "$f: missing summary blockquote (> ...) after # Title"

  # --- ## Related section (non-thread pages) ---
  if [[ "$f" != */threads/* ]]; then
    if ! grep -q '^## Related' "$f"; then
      check ERROR "$f: missing ## Related section"
    fi
  fi

  # --- ## Sources section ---
  if ! grep -q '^## Sources' "$f"; then
    check ERROR "$f: missing ## Sources section"
  fi

  # --- Frontmatter/body source desync ---
  fm_sources=$(awk '/^---$/{n++; next} n==1{print} n==2{exit}' "$f" \
    | { grep -oP 'raw/[a-zA-Z0-9_.-]+' || true; } | sort -u)
  body_sources=$(awk 'BEGIN{in_s=0} /^## Sources$/{in_s=1; next} in_s && /^## /{exit} in_s{print}' "$f" \
    | { grep -oP '`raw/[^`]+`' || true; } | tr -d '`' | { grep -oP 'raw/[a-zA-Z0-9_.-]+' || true; } | sort -u)

  fm_only=$(comm -23 <(echo "$fm_sources") <(echo "$body_sources") 2>/dev/null || true)
  body_only=$(comm -13 <(echo "$fm_sources") <(echo "$body_sources") 2>/dev/null || true)
  [ -n "$fm_only" ] && check ERROR "$f: sources in frontmatter but not ## Sources: $(echo "$fm_only" | tr '\n' ' ')"
  [ -n "$body_only" ] && check ERROR "$f: sources in ## Sources but not frontmatter: $(echo "$body_only" | tr '\n' ' ')"

  # --- Broken outbound [[wiki-links]] ---
  # Catch both [[slug]] and [[slug|Display]] forms
  # Strip inline code spans and fenced code blocks first so literal [[...]] inside
  # backticks (e.g. ManyIH privilege tags) are not treated as wiki-links.
  links=$(perl -0777 -pe 's/```.*?```//gs; s/`[^`]*`//g' "$f" \
    | grep -ohE '\[\[[a-z0-9-]+(\|[^]]*)?\]\]' 2>/dev/null | sort -u || true)
  if [ -n "$links" ]; then
    while IFS= read -r link; do
      # Extract slug: [[slug]] or [[slug|Display]]
      target="${link#\[\[}"
      target="${target%%|*}"
      target="${target%\]\]}"
      [ "$target" = "$slug" ] && continue
      if [ ! -f "wiki/${target}.md" ]; then
        if ! find wiki/ -name "${target}.md" | grep -q .; then
          check ERROR "$f: broken link [[${target}]]"
        fi
      fi
    done <<< "$links"
  fi

  # --- Orphan check ---
  hits=$(grep -rlE "\[\[${slug}(\|[^]]*)?\]\]" wiki/ --include='*.md' 2>/dev/null | grep -v "$f" | wc -l || echo 0)
  [ "$hits" -eq 0 ] && check WARN "$f: orphan (no inbound wiki-links)"

  # --- Index coverage ---
  if ! grep -qE "\[\[${slug}(\|[^]]*)?\]\]" wiki/index.md; then
    check WARN "$f: not listed in index.md"
  fi

  # --- Thread section for concept pages linked from threads ---
  if [[ "$f" == wiki/concepts/* ]]; then
    if grep -rqE "\[\[${slug}(\|[^]]*)?\]\]" wiki/threads/ 2>/dev/null; then
      if ! grep -q '^## Thread' "$f"; then
        check ERROR "$f: linked from thread but missing ## Thread section"
      fi
    fi
  fi

  # --- Epistemic callouts on thread pages ---
  # Any > [!note] or > [!warning] callout counts as epistemic signaling.
  # The four standard labels are Departure, Contradiction, Synthesis, Extension
  # (see meta/wiki-conventions.md), but other callout labels are acceptable.
  if [[ "$f" == wiki/threads/* ]]; then
    if ! grep -qE '^> \[!note\]|^> \[!warning\]' "$f" 2>/dev/null; then
      check WARN "$f: thread page missing epistemic callout (Departure/Contradiction/Synthesis/Extension or other note/warning)"
    fi
  fi

  # --- unaudited_marginal >= 5 ---
  count=$(grep -oP '^unaudited_marginal: \K\d+' "$f" 2>/dev/null || echo 0)
  [ "$count" -ge 5 ] && check WARN "$f: unaudited_marginal=$count (needs source verification)"
}

# --- Main ---

echo "=== Wiki Page Validator ==="
echo ""

if [ $# -eq 1 ]; then
  validate_one "$1"
else
  for f in $(find wiki/ -name "*.md" ! -name "index.md" | sort); do
    validate_one "$f"
  done
fi

echo ""
echo "=== Summary ==="
echo "Errors: $ERRORS"
echo "Warnings: $WARNS"

[ "$ERRORS" -gt 0 ] && exit 1
exit 0
