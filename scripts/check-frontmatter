#!/usr/bin/env bash
# check-frontmatter — verify required frontmatter fields and page structure
# Usage: check-frontmatter

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

read -r -d '' PROG <<'PERL' || true
BEGIN {
  @missing_fields = ();
  @missing_summary = ();
  @missing_related = ();
}

my $f = $ARGV;

# Required frontmatter fields.
if (/^---\r?\n(.*?)\r?\n---/s) {
  my $fm = $1;
  my $missing = '';
  for my $field (qw(title created updated sources tags)) {
    $missing .= " $field" unless $fm =~ /^$field:/m;
  }
  push @missing_fields, "$f: missing$missing" if $missing;
} else {
  push @missing_fields, "$f: missing title created updated sources tags";
}

# Summary blockquote immediately after # Title.
if (/^---\r?\n.*?\r?\n---\r?\n(.*)/s) {
  my $body = $1;
  if ($body =~ /^# /m) {
    my $tail = $body;
    $tail =~ s/^# [^\n]*\n//m;
    $tail =~ s/^\n+//;
    push @missing_summary, $f unless $tail =~ /^> /;
  } else {
    push @missing_summary, $f;
  }
}

# Related section (not for threads or index).
unless ($f =~ /wiki\/threads/ || $f eq 'wiki/index.md') {
  push @missing_related, $f unless /^## Related\b/m;
}

END {
  print "=== Missing required frontmatter fields ===\n";
  print "  $_\n" for @missing_fields;

  print "\n=== Missing summary blockquote after # title ===\n";
  print "  $_\n" for @missing_summary;

  print "\n=== Pages without ## Related section ===\n";
  print "  $_\n" for @missing_related;

  print "\nDone.\n";
}
PERL

fd -0 -e md . wiki/ -E 'index.md' | xargs -0 -r perl -0777 -ne "$PROG"
