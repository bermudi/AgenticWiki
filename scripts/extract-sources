#!/usr/bin/env bash
# extract-sources — print raw/ source paths from wiki page frontmatter or body
# Usage: extract-sources frontmatter wiki/page.md
#        extract-sources body wiki/page.md

set -euo pipefail

if [ $# -ne 2 ]; then
  echo "usage: extract-sources <frontmatter|body> <wiki-page.md>" >&2
  exit 2
fi

mode="$1"
file="$2"

case "$mode" in
  frontmatter)
    read -r -d '' PROG <<'PERL' || true
      /^---\n(.*?)\n---/s or next;
      my $fm = $1;
      while ($fm =~ /"(raw\/[^"]+)"|'(raw\/[^']+)'|(raw\/[^\s,"'\]\}\)]+)/g) {
        my $src = $1 || $2 || $3;
        print "$src\n" if defined $src;
      }
PERL
    perl -0777 -ne "$PROG" "$file" | sort -u
    ;;
  body)
    read -r -d '' PROG <<'PERL' || true
      if (/^## Sources\b\s*$(.*?)(?:^## |\Z)/ms) {
        my $s = $1;
        while ($s =~ /`(raw\/[^`]+)`/g) { print "$1\n"; }
      }
PERL
    perl -0777 -ne "$PROG" "$file" | sort -u
    ;;
  *)
    echo "unknown mode: $mode" >&2
    exit 2
    ;;
esac
