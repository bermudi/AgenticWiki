#!/usr/bin/env bash
# check-sources — verify frontmatter sources: list matches body ## Sources section
# Usage: check-sources

set -uo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "=== Frontmatter/body source desync ==="
for f in $(find wiki/ -name "*.md" ! -name "index.md" | sort); do
  # Extract raw/ filenames from YAML frontmatter (between first --- pair)
  fm_sources=$(awk '/^---$/{n++; next} n==1{print} n==2{exit}' "$f" \
    | grep -oP 'raw/[a-zA-Z0-9_.-]+' | sort -u)

  # Extract raw/ filenames from ## Sources section (backtick-wrapped)
  body_sources=$(awk 'BEGIN{in_s=0} /^## Sources$/{in_s=1; print; next} in_s && /^## /{exit} in_s{print}' "$f" \
    | grep -oP '`raw/[^`]+`' | tr -d '`' | grep -oP 'raw/[a-zA-Z0-9_.-]+' | sort -u)

  # Compare
  fm_only=$(comm -23 <(echo "$fm_sources") <(echo "$body_sources"))
  body_only=$(comm -13 <(echo "$fm_sources") <(echo "$body_sources"))

  [ -n "$fm_only" ] && echo "  $f: in frontmatter but not ## Sources: $(echo "$fm_only" | tr '\n' ' ')"
  [ -n "$body_only" ] && echo "  $f: in ## Sources but not frontmatter: $(echo "$body_only" | tr '\n' ' ')"
done

echo ""
echo "=== Pages with empty sources: in frontmatter ==="
for f in $(find wiki/ -name "*.md" ! -name "index.md" | sort); do
  count=$(awk '/^---$/{n++; next} n==1{print} n==2{exit}' "$f" | grep -cP 'raw/')
  [ "$count" -eq 0 ] && echo "  $f (no raw/ sources in frontmatter)"
done

echo ""
echo "Done."
